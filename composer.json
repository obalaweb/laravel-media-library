{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "codprez/laravel-media-library",
    "description": "Media library with upload, variants, and selector UI for Laravel + Inertia + React.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "media",
        "library",
        "inertia",
        "react",
        "media-manager",
        "upload"
    ],
    "authors": [
        {
            "name": "Codprez",
            "homepage": "https://github.com/obalaweb"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Codprez\\MediaLibrary\\": "src/",
            "Codprez\\MediaLibrary\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Codprez\\MediaLibrary\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Codprez\\MediaLibrary\\MediaLibraryServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
